{
  "mcpServers": {
    "dis-knowledge-base": {
      "type": "http",
      "url": "http://localhost:8000/mcp",
      "headers": {
        "Authorization": "Bearer dev-mcp-key-change-me"
      },
      "lifecycle": "lazy",
      "directTools": true
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": [
        "serve",
        "--mcp"
      ]
    }
  }
}
