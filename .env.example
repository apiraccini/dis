# Postgres (document metadata + parsed text; chunks live in Qdrant, not here)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=dis
POSTGRES_PASSWORD=dis
POSTGRES_DB=dis

# Qdrant (vectors + payload filtering by document/tag)
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# Embeddings via OpenRouter (OpenAI-compatible). Only the API key is secret;
# model/dimensions/chunk params have defaults in config.py and may be overridden here.
OPENROUTER_API_KEY=
# EMBEDDING_MODEL=qwen/qwen3-embedding-8b
# EMBEDDING_DIMENSIONS=1536
# EMBEDDING_BATCH_SIZE=64
# CHUNK_SIZE_TOKENS=1024
# CHUNK_OVERLAP_TOKENS=0
# USE_FAKE_EMBEDDER=false  # deterministic in-process embedder for e2e (no API key)

# MCP server auth (Bearer token on the /mcp endpoint). Change in prod.
MCP_API_KEY=dev-mcp-key-change-me

# CORS for the REST API (frontend origin(s))
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
