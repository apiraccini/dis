# Postgres (raw document metadata: documents, tags, chunks)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=dis
POSTGRES_PASSWORD=dis
POSTGRES_DB=dis

# Qdrant (vectors + payload filtering by document/tag)
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# Embeddings — model NOT decided yet; uncomment and set in the SDD session.
# OPENAI_API_KEY=
# EMBEDDING_MODEL=
# EMBEDDING_DIMENSIONS=

# MCP server auth (Bearer token on the /mcp endpoint). Change in prod.
MCP_API_KEY=dev-mcp-key-change-me

# CORS for the REST API (frontend origin(s))
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
